# Square
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox
DEMO_CHECKOUT_ONLY=true
ALLOW_LIVE_PAYMENTS=false
# Optional decimal tax rate. Example: 0.07 for 7%
CHECKOUT_TAX_RATE=0

# Neon Postgres
DATABASE_URL=postgres://username:password@host/dbname?sslmode=require

# Frontend + redirects
VITE_PUBLIC_SITE_URL=http://localhost:5173
CHECKOUT_SUCCESS_URL=http://localhost:5173/checkout/success
CHECKOUT_CANCEL_URL=http://localhost:5173/checkout/cancel

# Optional for webhook verification scaffolding
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key
